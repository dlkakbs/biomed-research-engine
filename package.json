{
  "name": "biomed-research",
  "version": "1.0.0",
  "private": true,
  "description": "Agentic biomedical research workflow on Arc with x402, Gateway, and ERC-8183",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm --workspace @biomed/web run dev",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "dev:api": "npm --workspace @biomed/api run dev",
    "register:identity": "python3 scripts/register-identity.py",
    "seed:demo": "node --import tsx scripts/seed-demo.ts"
  },
  "dependencies": {
    "@circle-fin/developer-controlled-wallets": "^10.2.0",
    "better-sqlite3": "^12.8.0",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "uuid": "^9.0.0",
    "web3": "^4.3.0",
    "x402-express": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "playwright": "^1.59.1",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
